# ─── Google Gemini API Keys (Auto-Rotation) ──────────────────────────────────
# Add at least one API key. The system will automatically rotate between them
# if one fails or hits rate limits.
# Get your keys from: https://aistudio.google.com/apikey
GOOGLE_API_KEY_A=
GOOGLE_API_KEY_B=
GOOGLE_API_KEY_C=
GOOGLE_API_KEY_D=
GOOGLE_API_KEY_E=
GOOGLE_API_KEY_F=

# ─── Rate Limiting (Upstash Redis) ──────────────────────────────────────────
# Optional: For production rate limiting. Leave empty for no rate limiting.
# Get credentials from: https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Code Execution (Judge0) ────────────────────────────────────────────────
# Local: docker run -p 2358:2358 judge0/judge0
# Production: Deploy to Hugging Face Spaces (see HUGGINGFACE_SETUP.md)
# Example: https://your-username-judge0.hf.space
JUDGE0_API_HOST=http://localhost:2358
