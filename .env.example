# ─── Google Gemini API Keys (Auto-Rotation) ──────────────────────────────────
# Add at least one API key. The system will automatically rotate between them
# if one fails or hits rate limits.
# Get your keys from: https://aistudio.google.com/apikey
GOOGLE_API_KEY_1=
GOOGLE_API_KEY_2=
GOOGLE_API_KEY_3=
GOOGLE_API_KEY_4=
GOOGLE_API_KEY_5=
GOOGLE_API_KEY_6=

# ─── Rate Limiting (Upstash Redis) ──────────────────────────────────────────
# Optional: For production rate limiting. Leave empty for no rate limiting.
# Get your credentials from: https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Code Execution (Judge0 Self-Hosted) ────────────────────────────────────
# Optional: For Code Runner tool. Leave empty to disable code execution.
# Self-hosted via Docker (localhost:2358) - No API key required
# Docker: docker run -p 2358:2358 judge0/judge0
JUDGE0_API_HOST=http://localhost:2358
